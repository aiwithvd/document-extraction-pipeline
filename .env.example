# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=docuser
POSTGRES_PASSWORD=docpassword
POSTGRES_DB=docextract
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://docuser:docpassword@localhost:5432/docextract
SYNC_DATABASE_URL=postgresql+psycopg2://docuser:docpassword@localhost:5432/docextract

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI  (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama  (used when LLM_PROVIDER=ollama)
# Start Ollama: docker run -p 11434:11434 ollama/ollama
# Pull model:   docker exec <container> ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=10485760

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
